{
  "ci": {
    "collect": {
      "url": ["http://localhost:8080/"],
      "numberOfRuns": 1
    },
    "assert": {
      "assertions": {
        "categories": {
          "performance": ["error", { "minScore": 0.82 }],
          "accessibility": ["error", { "minScore": 0.85 }],
          "best-practices": ["error", { "minScore": 0.85 }],
          "seo": ["error", { "minScore": 0.85 }],
          "pwa": ["warn", { "minScore": 0.40 }]
        }
      }
    }
  }
}
